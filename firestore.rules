rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data;
    }
    
    function isEmailAuthorized() {
      return exists(/databases/$(database)/documents/authorized_users/$(request.auth.uid));
    }
    
    function isActive() {
      return getUserData().active == true;
    }
    
    function getRole() {
      return getUserData().role;
    }
    
    function isAdmin() {
      return isAuthenticated() && isEmailAuthorized() && isActive() && getRole() == 'admin';
    }
    
    function isOwner() {
      return isAuthenticated() && isEmailAuthorized() && isActive() && getRole() == 'owner';
    }
    
    function isClerk() {
      return isAuthenticated() && isEmailAuthorized() && isActive() && getRole() == 'clerk';
    }

    // Rules for authorized_users collection
    match /authorized_users/{uid} {
      // Users can read their own role document to verify access
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      // Only admins can write (create, update, delete) user roles
      allow write: if isAdmin();
    }
    
    // Rules for projects collection
    match /projects/{projectId} {
      // Anyone with an active authorized account can read any project
      allow read: if isAuthenticated() && isEmailAuthorized() && isActive();
      
      // Creating projects: admin, owner, clerk are all allowed to create projects
      allow create: if isAuthenticated() && isEmailAuthorized() && isActive() && (getRole() == 'admin' || getRole() == 'owner' || getRole() == 'clerk');
      
      // Updating or Deleting projects: admins, owners, or clerks who created the project
      allow update, delete: if isAuthenticated() && isEmailAuthorized() && isActive() && (
        getRole() == 'admin' || 
        getRole() == 'owner' || 
        (getRole() == 'clerk' && resource.data.createdByUid == request.auth.uid)
      );
      
      // Rules for nested subcollections (such as photos)
      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && isEmailAuthorized() && isActive();
        
        allow create: if isAuthenticated() && isEmailAuthorized() && isActive() && (
          getRole() == 'admin' || 
          getRole() == 'owner' || 
          (getRole() == 'clerk' && get(/databases/$(database)/documents/projects/$(projectId)).data.createdByUid == request.auth.uid)
        );
        
        allow update, delete: if isAuthenticated() && isEmailAuthorized() && isActive() && (
          getRole() == 'admin' || 
          getRole() == 'owner' || 
          (getRole() == 'clerk' && get(/databases/$(database)/documents/projects/$(projectId)).data.createdByUid == request.auth.uid)
        );
      }
    }
  }
}
